---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Dkart Line | Nos Karts"
  description="Découvrez nos deux prototypes : le Kart Thermique et le Kart Électrique. Projet Drift Kart de l'UTT."
>
  <main class="karts-page dk-grain">
    <!-- Header -->
    <header class="karts-header">
      <a href="/" class="back-link">
        <span class="back-arrow">←</span>
        Retour à l'accueil
      </a>
      <div class="header-content">
        <h1 class="page-title dk-display">
          <span class="title-line">NOS</span>
          <span class="title-line title-line--accent">KARTS</span>
        </h1>
        <p class="page-desc dk-body">
          Deux visions. Une seule obsession : le drift perfomant.
        </p>
      </div>
    </header>

    <!-- Karts Grid -->
    <section class="karts-grid">
      <!-- Kart Thermique -->
      <article class="kart-card dk-reveal">
         <div class="kart-card__bg"></div>
         <div class="kart-card__content">
           <div class="top-row">
             <div class="kart-card__badge">Thermique</div>
             <div class="kart-card__status">
               <span class="pulse-dot"></span>
               En conception
             </div>
           </div>
           
           <h2 class="kart-card__title dk-display">PROTO T-01</h2>
           
           <div class="desc-placeholder">
              <p class="kart-card__desc dk-body">
                L’essence même du drift brut. Un châssis tubulaire conçu spécifiquement pour absorber la puissance mécanique.
              </p>
              
              <div class="coming-soon">
                <span class="coming-soon-line"></span>
                <span class="coming-soon-text dk-display">Bientôt Disponible</span>
                <span class="coming-soon-line"></span>
              </div>
           </div>
         </div>
      </article>

      <!-- Kart Électrique -->
      <article class="kart-card dk-reveal" style="transition-delay: 0.2s">
         <div class="kart-card__bg"></div>
         <div class="kart-card__content">
           <div class="top-row">
             <div class="kart-card__badge">Électrique</div>
             <div class="kart-card__status">
               <span class="pulse-dot pulse-dot--electric"></span>
               En conception
             </div>
           </div>
           
           <h2 class="kart-card__title dk-display">PROTO E-01</h2>
           
           <div class="desc-placeholder">
              <p class="kart-card__desc dk-body">
                Le futur du drift. Couple instantané, centre de gravité optimisé et accélération implacable pour une précision maximale.
              </p>
              
              <div class="coming-soon">
                <span class="coming-soon-line"></span>
                <span class="coming-soon-text dk-display">Bientôt Disponible</span>
                <span class="coming-soon-line"></span>
              </div>
           </div>
         </div>
      </article>
    </section>
  </main>
</LandingLayout>

<style>
  /* Base Layout */
  .karts-page {
    min-height: 100vh;
    padding: var(--dk-space-2xl) 5vw;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Header */
  .karts-header {
    width: 100%;
    max-width: 1200px;
    margin-bottom: var(--dk-space-xl);
    position: relative;
    z-index: 2;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--dk-font-display);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dk-secondary);
    margin-bottom: var(--dk-space-lg);
  }

  .back-link:hover {
    color: var(--dk-accent);
  }

  .back-link:hover .back-arrow {
    transform: translateX(-4px);
  }

  .back-arrow {
    font-size: 1.2rem;
    transition: transform var(--dk-transition-fast);
  }

  .header-content {
    animation: dk-fade-up 0.8s forwards;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    margin-bottom: var(--dk-space-sm);
  }

  .title-line {
    display: block;
    color: var(--dk-text);
  }

  .title-line--accent {
    background: linear-gradient(135deg, var(--dk-accent) 0%, var(--dk-silver-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(var(--dk-accent-rgb), 0.3));
  }

  .page-desc {
    font-style: italic;
    max-width: 600px;
    color: var(--dk-muted);
  }

  /* Grid */
  .karts-grid {
    width: 100%;
    max-width: 1200px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--dk-space-lg);
    z-index: 2;
  }

  /* Cards */
  .kart-card {
    position: relative;
    background: var(--dk-bg-elevated);
    border: 1px solid var(--dk-border);
    padding: var(--dk-space-lg);
    overflow: hidden;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: transform var(--dk-transition), box-shadow var(--dk-transition), border-color var(--dk-transition);
  }

  .kart-card:hover {
    transform: translateY(-5px);
    border-color: rgba(var(--dk-accent-rgb), 0.5);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(var(--dk-accent-rgb), 0.05);
  }

  .kart-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--dk-accent);
    opacity: 0.3;
    transition: opacity var(--dk-transition);
  }

  .kart-card:hover::before {
    opacity: 1;
    box-shadow: 0 0 15px var(--dk-accent);
  }

  /* Decorative Background Inside Card */
  .kart-card__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top right,
      rgba(var(--dk-accent-rgb), 0.03) 0%,
      transparent 60%
    );
    z-index: 0;
  }

  .kart-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Badges & Status */
  .top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: auto;
  }

  .kart-card__badge {
    font-family: var(--dk-font-display);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dk-bg);
    background: var(--dk-text);
    padding: 0.25rem 0.75rem;
  }

  .kart-card__status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--dk-font-display);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dk-muted);
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--dk-accent);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--dk-accent);
    animation: dk-pulse 2s infinite;
  }
  
  .pulse-dot--electric {
    background: var(--dk-accent);
    box-shadow: 0 0 8px rgba(var(--dk-accent-rgb), 0.6);
  }

  @keyframes dk-pulse {
    0% { transform: scale(0.95); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 1; }
    100% { transform: scale(0.95); opacity: 0.5; }
  }

  /* Titles */
  .kart-card__title {
    font-size: 2.5rem;
    line-height: 1;
    margin-top: var(--dk-space-xl);
    margin-bottom: var(--dk-space-sm);
  }

  /* Description & Coming Soon Placeholder */
  .desc-placeholder {
    position: relative;
    padding-top: var(--dk-space-md);
    border-top: 1px solid var(--dk-border);
  }

  .kart-card__desc {
    color: var(--dk-secondary);
    font-size: 0.95rem;
    margin-bottom: var(--dk-space-lg);
    opacity: 0.5; /* Fade description to show it's not the main focus right now */
  }

  .coming-soon {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1rem;
    background: rgba(var(--dk-accent-rgb), 0.05);
    border: 1px dashed rgba(var(--dk-accent-rgb), 0.3);
  }

  .coming-soon-line {
    flex-grow: 1;
    height: 1px;
    background: rgba(var(--dk-accent-rgb), 0.3);
  }

  .coming-soon-text {
    font-size: 0.85rem;
    color: var(--dk-accent);
    letter-spacing: 0.2em;
    text-shadow: 0 0 10px rgba(var(--dk-accent-rgb), 0.2);
  }

  @media (max-width: 768px) {
    .karts-page {
      padding: var(--dk-space-xl) 5vw;
    }
    
    .kart-card {
      min-height: 400px;
    }
  }
</style>

<script>
  // Simple intersection observer to trigger reveals
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.dk-reveal').forEach(el => {
      observer.observe(el);
    });
  });
</script>
