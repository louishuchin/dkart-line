---
import LandingLayout from '../layouts/LandingLayout.astro';

const title = "404 - Hors Piste | Dkart Line";
const description = "Désolé, cette page est sortie de la piste. Revenez dans la course !";
---

<LandingLayout title={title} description={description}>
  <main class="error-page dk-grain">
    <div class="error-content">
      <div class="error-code dk-display dk-text-glow">404</div>
      <h1 class="error-title dk-display">Hors Piste !</h1>
      <p class="error-text">
        Désolé, il semble que vous ayez pris un virage un peu trop large. Cette page n'existe pas ou a été déplacée.
      </p>
      <div class="error-actions">
        <a href="/" class="dk-btn">
          Retourner au Stand
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M19 12H5M5 12L12 19M5 12L12 5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </main>
</LandingLayout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--dk-space-xl);
    background-color: var(--dk-bg);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Decorative speed lines in background */
  .error-page::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200%;
    height: 200%;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 100px,
      rgba(var(--dk-accent-rgb), 0.03) 100px,
      rgba(var(--dk-accent-rgb), 0.03) 101px
    );
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .error-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    animation: dk-fade-up 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .error-code {
    font-size: clamp(6rem, 15vw, 10rem);
    color: var(--dk-accent);
    line-height: 0.8;
    margin-bottom: var(--dk-space-md);
    opacity: 0.9;
  }

  .error-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: var(--dk-space-sm);
    color: var(--dk-text);
  }

  .error-text {
    font-family: var(--dk-font-body);
    font-size: 1.1rem;
    color: var(--dk-secondary);
    margin-bottom: var(--dk-space-lg);
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    justify-content: center;
  }

  @keyframes dk-fade-up {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
