---
/**
 * DKART LINE — Timeline Section ("L'Histoire")
 * Vertical timeline with scroll-triggered reveal animations.
 * Each milestone from the source story, rewritten in punchy event-ready tone.
 */

const milestones = [
  {
    period: "Les racines",
    year: "L'origine",
    title: "Dans le sang",
    body: "Issus de milieux de passionnés de mécanique — certains parents à moto, d'autres proches mécanos, des familles de manuels. C'est depuis petit que cette envie de bricoler, créer, réparer est apparue pour créer nos premiers prototypes. Débuts sur des pocket bikes ou de vieux moteurs. En parallèle, les premières créations voient le jour.",
    icon: "🔧",
  },
  {
    period: "Troisième semestre",
    year: "L'idée",
    title: "L'envie de drift",
    body: "L'idée du karting de drift prend forme. Elle vient d'un ancien projet inabouti avec un ami : construire un drift trike. L'idée, elle, est restée. Jugé trop ambitieux pour un projet étudiant en deuxième année. Il va falloir attendre. Ou pas. Persuadé du potentiel, la décision est prise de foncer quand même. Motivé pour travailler seul, en parallèle d'un rythme de cours déjà lourd.",
    icon: "💡",
  },
  {
    period: "Dans le box",
    year: "Construction",
    title: "Un kart qui roule",
    body: "Le premier prototype voit le jour. Il roule, mais cumule les problèmes : le feeling de drift n'est pas correct. Alors qu'il n'est même pas abouti, l'audace paie : multiples échanges avec le championnat de drift. L'objectif est clair : redoubler d'efforts avant la date clé pour y décrocher sa place dans le monde réel",
    icon: "🏎️",
  },
  {
    period: "Troisième année",
    year: "Le tournant",
    title: "Dimension supérieure",
    body: "Nouvelle tentative : le projet étudiant est accepté ! Fini de travailler seul, l'équipe passe à quatre. Les exigences du projet sont revues à la hausse. Fort de l'expérience et des contacts du premier prototype, on efface tout et on recommence. Optimisation, correction des problèmes. Beaucoup de travail et une forte autonomie pour mener à bien le projet malgré les nombreuses difficultés rencontrées.",
    icon: "🤝",
  },
  {
    period: "L'aboutissement",
    year: "Aujourd'hui",
    title: "Le drift, enfin",
    body: "Après des mois et des mois de travail acharné, le kart fonctionne et est agréable à manier pour les pilotes. La détermination paie : un stand est officiellement obtenu sur la manche d'ouverture du Championnat de France de Drift.",
    icon: "🏁",
  },
  {
    period: "La reconstruction",
    year: "Optimisation",
    title: "Un futur prometteur",
    body: "Ceci n'est que le début d'une longue histoire. L'équipe a de nombreuses idées et nous sommes très optimistes pour la suite. Et pour ça nous aurons <a href=\"/soutenez-nous\" class=\"dk-link-inline\">besoin de vous</a>",
    icon: "🛠️",
  },
];
---

<section id="histoire" class="timeline dk-grain">
  <div class="timeline__header dk-reveal">
    <span class="timeline__label">L'Histoire</span>
    <h2 class="timeline__title dk-display">
      Un projet pensé depuis<br /><span class="dk-text-accent">toujours</span>
    </h2>
    <p class="timeline__subtitle">
      Avant même qu'il y ait une idée de conception, il y a eu un environnement,
      une passion, et une envie constante de créer.
    </p>
  </div>

  <div class="timeline__track">
    <!-- Vertical line -->
    <div class="timeline__line" aria-hidden="true"></div>

    {
      milestones.map((m, i) => (
        <div
          class={`timeline__item dk-reveal ${i % 2 === 0 ? "timeline__item--left" : "timeline__item--right"}`}
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div class="timeline__dot" aria-hidden="true">
            <span class="timeline__dot-icon">{m.icon}</span>
          </div>
          <div class="timeline__card">
            <div class="timeline__card-header">
              <span class="timeline__period">{m.period}</span>
              <span class="timeline__year">{m.year}</span>
            </div>
            <h3 class="timeline__card-title dk-display">{m.title}</h3>
            <p class="timeline__card-body" set:html={m.body} />
          </div>
        </div>
      ))
    }
  </div>

  <!-- Closing statement -->
  <div class="timeline__closing dk-reveal">
    <div class="timeline__closing-border"></div>
    <blockquote class="timeline__closing-quote dk-display">
      "Né d'une passion pour les sports mécaniques,<br />
      et d'une envie constante de créer et de construire.<br />
      <span class="dk-text-accent">Ce n'est que le début.</span>"
    </blockquote>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    padding: var(--dk-space-3xl) var(--dk-space-lg);
    background: linear-gradient(135deg, #080c12 0%, #0a1628 50%, #0d1f3c 100%);
    overflow: hidden;
  }

  /* ---- Header ---- */
  .timeline__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--dk-space-3xl);
  }

  .timeline__label {
    display: inline-block;
    font-family: var(--dk-font-display);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--dk-accent);
    margin-bottom: var(--dk-space-sm);
    padding: 0.4rem 1rem;
    border: 1px solid rgba(var(--dk-accent-rgb), 0.3);
  }

  .timeline__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    margin-bottom: var(--dk-space-md);
    color: var(--dk-text);
  }

  .timeline__subtitle {
    font-family: var(--dk-font-body);
    font-size: 1.1rem;
    color: var(--dk-secondary);
    line-height: 1.7;
  }

  /* ---- Track ---- */
  .timeline__track {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--dk-space-xl) 0;
  }

  .timeline__line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--dk-border) 5%,
      var(--dk-border) 95%,
      transparent 100%
    );
    transform: translateX(-50%);
  }

  /* ---- Item ---- */
  .timeline__item {
    position: relative;
    display: flex;
    align-items: flex-start;
    margin-bottom: var(--dk-space-xl);
    width: 100%;
  }

  .timeline__item--left {
    justify-content: flex-start;
    padding-right: calc(50% + 40px);
  }

  .timeline__item--right {
    justify-content: flex-end;
    padding-left: calc(50% + 40px);
  }

  /* ---- Dot ---- */
  .timeline__dot {
    position: absolute;
    left: 50%;
    top: 0.5rem;
    transform: translateX(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--dk-bg-elevated);
    border: 2px solid var(--dk-border);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition:
      border-color var(--dk-transition),
      box-shadow var(--dk-transition);
  }

  .timeline__item.is-visible .timeline__dot {
    border-color: var(--dk-accent);
    box-shadow: 0 0 20px rgba(var(--dk-accent-rgb), 0.2);
  }

  .timeline__dot-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  /* ---- Card ---- */
  .timeline__card {
    width: 100%; /* Force full available width */
    background: var(--dk-bg-elevated);
    border: 1px solid var(--dk-border);
    padding: var(--dk-space-md) var(--dk-space-lg);
    position: relative;
    transition:
      border-color var(--dk-transition),
      box-shadow var(--dk-transition);
  }

  .timeline__item.is-visible .timeline__card {
    border-color: rgba(var(--dk-accent-rgb), 0.15);
  }

  .timeline__card:hover {
    border-color: rgba(var(--dk-accent-rgb), 0.3);
    box-shadow: 0 0 30px rgba(var(--dk-accent-rgb), 0.05);
  }

  .timeline__card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .timeline__period {
    font-family: var(--dk-font-display);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dk-accent);
    padding: 0.2rem 0.6rem;
    border: 1px solid rgba(var(--dk-accent-rgb), 0.3);
  }

  .timeline__year {
    font-family: var(--dk-font-display);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--dk-muted);
    letter-spacing: 0.1em;
  }

  .timeline__card-title {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--dk-text);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .timeline__card-body {
    font-family: var(--dk-font-body);
    font-size: 0.95rem;
    color: var(--dk-secondary);
    line-height: 1.65;
    white-space: pre-line;
  }

  .dk-link-inline {
    color: var(--dk-accent);
    text-decoration: none;
    font-weight: 700;
    border-bottom: 2px solid rgba(var(--dk-accent-rgb), 0.4);
    transition: all var(--dk-transition-fast);
  }

  .dk-link-inline:hover {
    color: var(--dk-text);
    border-bottom-color: var(--dk-accent);
    background: rgba(var(--dk-accent-rgb), 0.1);
    box-shadow: 0 0 15px rgba(var(--dk-accent-rgb), 0.2);
  }

  /* ---- Closing ---- */
  .timeline__closing {
    max-width: 800px;
    margin: var(--dk-space-3xl) auto 0;
    text-align: center;
  }

  .timeline__closing-border {
    width: 60px;
    height: 3px;
    background: var(--dk-accent);
    margin: 0 auto var(--dk-space-lg);
  }

  .timeline__closing-quote {
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    color: var(--dk-text);
    line-height: 1.4;
    letter-spacing: 0.02em;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .timeline__line {
      left: 24px;
    }

    .timeline__item--left,
    .timeline__item--right {
      padding-left: 64px;
      padding-right: 0;
      justify-content: flex-start;
    }

    .timeline__dot {
      left: 24px;
      width: 40px;
      height: 40px;
    }

    .timeline__dot-icon {
      font-size: 1rem;
    }

    .timeline__card {
      padding: var(--dk-space-md);
    }
  }
</style>
