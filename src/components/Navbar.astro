---
interface Props {
  currentPage?: string;
}

const { currentPage = 'accueil' } = Astro.props;

const navItems = [
  { label: 'Accueil', path: '/', id: 'accueil' },
  { label: 'Soutenez-nous', path: '/soutenez-nous', id: 'soutenez-nous' },
  { label: 'Qui Sommes-Nous ?', path: '/equipe', id: 'equipe' },
  { label: 'Nous Contacter', path: '/contact', id: 'contact' },
];
---

<nav class="navbar dk-grain">
  <div class="navbar__inner">
    <a href="/" class="navbar__brand dk-display" aria-label="Retour à l'accueil">
      <img src="/favicon.png" alt="Dkart Line Logo" class="navbar__logo" />
      DKART<span class="dk-text-accent">LINE</span>
    </a>

    <button class="navbar__toggle" aria-expanded="false" aria-label="Menu" id="navbar-toggle">
      <span class="navbar__toggle-line"></span>
      <span class="navbar__toggle-line"></span>
      <span class="navbar__toggle-line"></span>
    </button>

    <div class="navbar__menu" id="navbar-menu">
      <ul class="navbar__list">
        {navItems.map((item) => (
          <li class="navbar__item">
            <a 
              href={item.path} 
              class={`navbar__link dk-display ${currentPage === item.id ? 'is-active' : ''}`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('navbar-toggle');
    const menu = document.getElementById('navbar-menu');

    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', (!isExpanded).toString());
        toggle.classList.toggle('is-open');
        menu.classList.toggle('is-open');
      });
    }
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 80px;
    background: rgba(14, 20, 32, 0.95); /* Matches --dk-bg-elevated with opacity */
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--dk-border);
    z-index: 1000;
    display: flex;
    align-items: center;
    transition: transform var(--dk-transition);
  }

  .navbar::after {
    opacity: 0.3;
  }

  .navbar__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--dk-space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 2;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    color: var(--dk-text);
  }

  .navbar__logo {
    height: 56px;
    width: auto;
    filter: drop-shadow(0 0 10px rgba(var(--dk-accent-rgb), 0.3));
  }

  .navbar__list {
    display: flex;
    align-items: center;
    gap: var(--dk-space-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--dk-secondary);
    position: relative;
    transition: color var(--dk-transition-fast);
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--dk-accent);
    transform: translateX(-50%);
    transition: width var(--dk-transition);
  }

  .navbar__link:hover,
  .navbar__link.is-active {
    color: var(--dk-text);
  }

  .navbar__link.is-active::after {
    width: calc(100% - 2rem);
    box-shadow: 0 0 10px rgba(var(--dk-accent-rgb), 0.5);
  }

  .navbar__link:hover::after {
    width: calc(100% - 2rem);
  }

  /* Mobile Toggle */
  .navbar__toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 20px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 3;
  }

  .navbar__toggle-line {
    width: 100%;
    height: 2px;
    background: var(--dk-text);
    transition: transform var(--dk-transition-fast), opacity var(--dk-transition-fast);
  }

  .navbar__toggle.is-open .navbar__toggle-line:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .navbar__toggle.is-open .navbar__toggle-line:nth-child(2) {
    opacity: 0;
  }
  .navbar__toggle.is-open .navbar__toggle-line:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .navbar__toggle {
      display: flex;
    }

    .navbar__menu {
      position: fixed;
      top: 80px;
      left: 0;
      width: 100%;
      height: calc(100vh - 80px);
      background: var(--dk-bg);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-10px);
      transition: opacity var(--dk-transition), transform var(--dk-transition);
      border-top: 1px solid var(--dk-border);
    }

    .navbar__menu.is-open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .navbar__list {
      flex-direction: column;
      gap: var(--dk-space-lg);
    }

    .navbar__link {
      font-size: 1.25rem;
    }
    
    .navbar__link.is-active::after,
    .navbar__link:hover::after {
      width: 50%;
    }
  }
</style>
