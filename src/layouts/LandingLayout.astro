---
import Navbar from '../components/Navbar.astro';
import SpeedInsights from "@vercel/speed-insights/astro"

interface Props {
  title: string;
  description: string;
  currentPage?: string;
}

const { title, description, currentPage } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080C12" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={`https://dkart-line.fr${Astro.url.pathname}`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://dkart-line.fr${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://dkart-line.fr/og-image.png" />
    <meta property="og:site_name" content="Dkart Line" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`https://dkart-line.fr${Astro.url.pathname}`} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://dkart-line.fr/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png?v=3" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Dkart Line",
        "url": "https://dkart-line.fr",
        "logo": "https://dkart-line.fr/favicon.png",
        "description": "Projet de Drift Kart étudiant à l'UTT, alliant ingénierie et passion pour les sports mécaniques.",
        "sameAs": [
          "https://instagram.com/dkartline"
        ]
      }
    </script>

    <!-- Google Fonts — Chakra Petch (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <Navbar currentPage={currentPage} />
    <slot />
    <style is:global>
      @import '../styles/brand.css';
    </style>
    <script>
      // Scroll-triggered reveal via IntersectionObserver
      document.addEventListener("DOMContentLoaded", () => {
        const reveals = document.querySelectorAll(".dk-reveal");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
              }
            });
          },
          {
            threshold: 0.1,
            rootMargin: "0px 0px -60px 0px",
          },
        );

        reveals.forEach((el) => observer.observe(el));
      });
    </script>
    <SpeedInsights />
  </body>
</html>
